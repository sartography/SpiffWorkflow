    <bpmn:scriptTask id="Activity_1mkwgut" name="Create Items">
      <bpmn:incoming>Flow_1r3h9c0</bpmn:incoming>
      <bpmn:outgoing>Flow_03tsmi6</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0g953rt">
        <bpmn:targetRef>DataObjectReference_04mspxz</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:script>item = {
      "status": 0,
      "reason": None,
      "alphabet": ["a","b","c","d","e"],
      "billy_hoel_quote": "I am no longer afraid of becoming lost, because the journey back always reveals something new, and that is ultimately good for the artist."   
}

items = [item]*20
del(item)
i=0</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_06pqwzi" name="copy item into task data so I can read it">
